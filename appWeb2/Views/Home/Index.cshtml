@model IEnumerable<appWeb2.Models.VideoJuegos>
@{
    ViewData["Title"] = "Videojuegos";
}

<div class="container mt-5">
    <div class="row text-center mb-5">

        <!-- CATEGORÍAS -->
        <div class="col-md-3 mb-3">
            <a asp-action="Categorias" asp-controller="VideoJuegos" style="text-decoration:none; color:inherit;">
                <div class="feature-card">
                    <i class="fas fa-gamepad"></i>
                    <h5>Categorías</h5>
                    <p>Explora por tipo de juego</p>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a asp-action="Index" style="text-decoration:none; color:inherit;">
                <div class="feature-card">
                    <i class="fas fa-fire"></i>
                    <h5>Más Vendidos</h5>
                    <p>Los juegos más populares</p>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a asp-action="Nuevos" asp-controller="VideoJuegos" style="text-decoration:none; color:inherit;">
                <div class="feature-card">
                    <i class="fas fa-star"></i>
                    <h5>Nuevos Juegos</h5>
                    <p>Lo último en la tienda</p>
                </div>
            </a>
        </div>

        <!-- PROMOCIONES -->
        <div class="col-md-3 mb-3">
            <a asp-action="Promociones" asp-controller="VideoJuegos" style="text-decoration:none; color:inherit;">
                <div class="feature-card">
                    <i class="fas fa-tags"></i>
                    <h5>Promociones</h5>
                    <p>Ofertas especiales</p>
                </div>
            </a>
        </div>

    </div>

    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;">
        Videojuegos Disponibles
    </h2>

    <div class="row g-4">
        @foreach (var juegos in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100">

                    <!-- BADGE DINÁMICO -->
                    <div class="badge-top">+@juegos.EdadMinima</div>

                    <!--FAVORITO -->
                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <!-- IMAGEN -->
                    <img src="@juegos.Imagen"
                         class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">

                        <!-- TÍTULO -->
                        <h5 class="card-title fw-bold">
                            @juegos.Titulo
                        </h5>

                        <!-- PRECIO -->
                        <h4 class="price mt-2">
                            $@juegos.Precio
                        </h4>

                        <!-- CATEGORÍA -->
                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted fw-semibold">
                                @juegos.Categoria?.Nombre
                            </span>
                        </div>

                        @if (juegos.EnPromocion)
                        {
                            <span class="badge bg-danger mt-2">En promoción</span>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
</div>